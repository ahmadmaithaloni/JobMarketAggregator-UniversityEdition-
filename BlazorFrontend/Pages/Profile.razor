@page "/profile"
@inject ApiService Api
@inject NavigationManager Nav

<div class="container fade-in" style="max-width: 800px; padding-top: 1rem; padding-bottom: 4rem;">
    @if (Api.CurrentUser == null)
    {
        <div class="card" style="text-align: center; padding: 4rem 2rem;">
            <div style="margin-bottom: 1rem; color: var(--text-muted);">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h3 style="margin-bottom: 1rem;">Guest Access</h3>
            <p style="margin-bottom: 2rem; color: var(--text-muted);">Please login to manage your profile.</p>
            <a href="/" class="btn btn-primary">Login Now</a>
        </div>
    }
    else
    {
        <!-- Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h1 style="font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.75rem; margin: 0;">My Profile</h1>
            <button class="btn" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.9rem; padding: 0.5rem 1rem;" @onclick="Logout">
                <span style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logout
                </span>
            </button>
        </div>

        <!-- Profile Card -->
        <div class="card" style="padding: 2rem;">
            
            <!-- Avatar Section -->
            <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 2rem;">
                <div style="width: 100px; height: 100px; background-color: var(--input-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; border: 2px solid var(--border); color: var(--text-muted);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <h2 style="margin: 0; font-size: 1.25rem;">@displayUserName</h2>
                <span style="color: var(--text-muted); font-size: 0.9rem;">@Api.CurrentUser.UserEmail</span>
                
                @if (isEditing)
                {
                     <button class="btn" style="margin-top: 1rem; font-size: 0.85rem; color: var(--primary);" @onclick="ToggleEdit">
                        Cancel Editing
                    </button>
                }
                else
                {
                    <button class="btn" style="margin-top: 1rem; font-size: 0.85rem; border: 1px solid var(--border);" @onclick="ToggleEdit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.5rem;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Edit Profile
                    </button>
                }
            </div>

            <!-- Edit Form -->
            @if (isEditing)
            {
                <div class="fade-in">
                    <h3 style="font-size: 1.1rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Personal Details
                    </h3>
                    
                    <div style="display: grid; gap: 1.5rem; margin-bottom: 2rem;">
                        <div>
                            <label class="input-label">Full Name</label>
                            <input @bind="editName" class="form-control" placeholder="Your Name" />
                        </div>
                        <div>
                            <label class="input-label">Major / Title</label>
                            <input @bind="editMajor" class="form-control" placeholder="Software Engineering" />
                        </div>
                        <div>
                            <label class="input-label">Phone Number</label>
                            <input @bind="editPhone" class="form-control" placeholder="07XXXXXXXX" />
                        </div>
                         <div>
                            <label class="input-label">Address / Location</label>
                            <input @bind="editAddress" class="form-control" placeholder="Amman, Jordan" />
                        </div>
                    </div>

                    <h3 style="font-size: 1.1rem; margin-bottom: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        Security
                    </h3>
                     
                    <div style="display: grid; gap: 1.5rem; margin-bottom: 2rem;">
                         <div>
                            <label class="input-label">Email Address</label>
                            <input @bind="editEmail" class="form-control" placeholder="name@example.com" />
                        </div>
                        <div>
                            <label class="input-label">New Password (Optional)</label>
                            <input @bind="editPassword" type="password" class="form-control" placeholder="Leave empty to keep current" />
                        </div>
                    </div>

                    <button class="btn btn-primary" style="width: 100%; justify-content: center;" @onclick="SaveChanges" disabled="@isSaving">
                        @if(isSaving)
                        {
                            <span>Saving Changes...</span>
                        }
                        else 
                        {
                            <span>Save All Changes</span>
                        }
                    </button>
                </div>
            }
            else
            {
                <!-- Read-only View -->
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
                    <div>
                        <div style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">Major</div>
                        <div style="font-weight: 500;">@Api.CurrentUser.UserMajor</div>
                    </div>
                    <div>
                        <div style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">Phone</div>
                        <div style="font-weight: 500;">@Api.CurrentUser.UserPhone</div>
                    </div>
                    <div>
                         <div style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">Location</div>
                        <div style="font-weight: 500;">@Api.CurrentUser.UserAddress</div>
                    </div>
                     <div>
                         <div style="font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem;">Joined</div>
                        <div style="font-weight: 500;">@Api.CurrentUser.CreationDate.ToString("MMMM yyyy")</div>
                    </div>
                </div>
            }
        </div>
        
        @if (!string.IsNullOrEmpty(message))
        {
            <div style="margin-top: 1rem; padding: 1rem; border-radius: 8px; display: flex; align-items: center; gap: 0.75rem; color: @(isError ? "#ef4444" : "#16a34a"); background-color: @(isError ? "rgba(239,68,68,0.1)" : "rgba(34,197,94,0.1)"); border: 1px solid @(isError ? "rgba(239,68,68,0.2)" : "rgba(34,197,94,0.2)");">
                @if (isError) {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                } else {
                     <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                }
                @message
            </div>
        }
    }
    
    <div style="height: 60px;"></div>
</div>

@code {
    private bool isEditing = false;
    private bool isSaving = false;
    private string message = "";
    private bool isError = false;

    // Edit fields
    private string editName = "";
    private string editMajor = "";
    private string editPhone = "";
    private string editAddress = "";
    private string editEmail = "";
    private string editPassword = "";
    
    // Display helping vars
    private string displayUserName => Api.CurrentUser?.UserName ?? "User";

    private void ToggleEdit()
    {
        if (!isEditing)
        {
            // Init fields
            editName = Api.CurrentUser.UserName;
            editMajor = Api.CurrentUser.UserMajor;
            editPhone = Api.CurrentUser.UserPhone;
            editAddress = Api.CurrentUser.UserAddress;
            editEmail = Api.CurrentUser.UserEmail;
            editPassword = "";
            message = "";
        }
        isEditing = !isEditing;
    }

    private async Task SaveChanges()
    {
        isSaving = true;
        message = "";
        isError = false;
        
        try
        {
            // Sequential updates (simplest implementation given separate endpoints)
            // In a production app, we might want a single UpdateProfile endpoint, 
            // but here we must call each specific controller action.
            
            bool changed = false;

            if (editName != Api.CurrentUser.UserName) { await Api.UpdateUserName(editName); changed = true; }
            if (editMajor != Api.CurrentUser.UserMajor) { await Api.UpdateMajor(editMajor); changed = true; }
            if (editPhone != Api.CurrentUser.UserPhone) { await Api.UpdatePhone(editPhone); changed = true; }
            if (editAddress != Api.CurrentUser.UserAddress) { await Api.UpdateAddress(editAddress); changed = true; }
            if (editEmail != Api.CurrentUser.UserEmail) { await Api.UpdateEmail(editEmail); changed = true; }
            
            if (!string.IsNullOrWhiteSpace(editPassword)) 
            {
               await Api.UpdatePassword(editPassword);
               changed = true;
            }

            if (changed)
            {
                 message = "Profile updated successfully!";
                 isEditing = false;
            }
            else
            {
                message = "No changes detected.";
            }

        }
        catch (Exception ex)
        {
            isError = true;
            message = "Update failed: " + ex.Message;
            // Stay in edit mode so user can fix
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Logout()
    {
        Api.Logout();
        Nav.NavigateTo("/");
    }
}
