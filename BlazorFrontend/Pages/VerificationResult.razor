@page "/verification-result"
@inject NavigationManager Nav

<div class="container fade-in" style="width: 100%; height: 80vh; display: flex; align-items: center; justify-content: center;">
    <div class="card" style="padding: 3rem; border: 1px solid var(--border); background: var(--bg-card); box-shadow: var(--shadow); text-align: center; max-width: 450px; width: 90%;">
        
        @if (IsSuccess)
        {
            <!-- Success State -->
            <div style="margin-bottom: 2rem;">
                <div style="width: 80px; height: 80px; background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; margin-bottom: 1.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <h1 style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 2rem; margin-bottom: 0.5rem; color: var(--text-primary);">
                    Verified!
                </h1>
                <p style="font-size: 1rem; color: var(--text-muted);">
                    Your account has been successfully verified.
                </p>
                <p style="font-size: 0.9rem; color: var(--primary-color); font-weight: 600; margin-top: 1.5rem;">
                    Redirecting to Login in @countdown...
                </p>
            </div>
        }
        else
        {
            <!-- Failure State -->
            <div style="margin-bottom: 2rem;">
                <div style="width: 80px; height: 80px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; margin-bottom: 1.5rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
                <h1 style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 2rem; margin-bottom: 0.5rem; color: var(--text-primary);">
                    Failed
                </h1>
                <p style="font-size: 1rem; color: var(--text-muted);">
                    @ErrorMessage
                </p>
            </div>
            
            <button class="btn btn-primary" @onclick="GoBack" style="width: 100%; padding: 1rem;">
                Try Again
            </button>
        }

    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Status { get; set; }

    [SupplyParameterFromQuery]
    public string? Message { get; set; }

    private bool IsSuccess => Status?.ToLower() == "success";
    private string ErrorMessage => Message ?? "Verification failed. Please check the code and try again.";
    private int countdown = 3;

    protected override async Task OnInitializedAsync()
    {
        if (IsSuccess)
        {
            while (countdown > 0)
            {
                await Task.Delay(1000);
                countdown--;
                StateHasChanged();
            }
            Nav.NavigateTo("/login");
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/verify-account"); // Or history back if possible, but safe link is better
    }
}
