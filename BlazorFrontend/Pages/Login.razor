@page "/"
@page "/login"
@inject ApiService Api
@inject NavigationManager Nav

<style>
    .is-invalid {
        border-color: #ef4444 !important;
        background-color: rgba(239, 68, 68, 0.05) !important;
    }
    .invalid-feedback {
        color: #ef4444;
        font-size: 0.85rem;
        margin-top: 0.25rem;
        margin-left: 2px;
    }
</style>

<div class="container fade-in" style="width: 90%; max-width: 420px; padding-top: 6vh; margin: 0 auto;">
    <div class="card" style="padding: 2.5rem; border: 1px solid var(--border); background: var(--bg-card); box-shadow: var(--shadow);">
        
        <div style="text-align: center; margin-bottom: 2.5rem;">
            <h1 style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 2rem; margin-bottom: 0.5rem; background: var(--hero-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1.2;">
                Aggregating<br>Opportunities
            </h1>
            <p style="font-size: 1rem; color: var(--text-muted);">
                Your gateway to the global job market.
            </p>
        </div>
        
        <div class="input-group" style="margin-bottom: 1.25rem; text-align: left;">
            <label class="input-label" style="margin-left: 2px;">Email Address <span style="color: #ef4444;">*</span></label>
            <input @bind="email" class="form-control @(Errors.ContainsKey("Email") ? "is-invalid" : "")" type="email" placeholder="name@company.com" style="padding: 1rem;" />
            @if (Errors.ContainsKey("Email")) { <div class="invalid-feedback">@Errors["Email"]</div> }
        </div>

        <div class="input-group" style="margin-bottom: 2rem; text-align: left;">
            <label class="input-label" style="margin-left: 2px;">Password <span style="color: #ef4444;">*</span></label>
            <div style="position: relative;">
                <input @bind="password" class="form-control @(Errors.ContainsKey("Password") ? "is-invalid" : "")" type="@(showPassword ? "text" : "password")" placeholder="••••••••" style="padding: 1rem; padding-right: 2.5rem;" />
                 <button type="button" @onclick="() => showPassword = !showPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-muted); cursor: pointer; display: flex; align-items: center;">
                    @if (showPassword)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    }
                </button>
            </div>
            @if (Errors.ContainsKey("Password")) { <div class="invalid-feedback">@Errors["Password"]</div> }
        </div>

        @if (!string.IsNullOrEmpty(GlobalError))
        {
            <div style="background-color: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; font-size: 0.9rem; padding: 0.75rem; border-radius: var(--radius); margin-bottom: 1.5rem; text-align: center;">
                @GlobalError
                @if (GlobalError.Contains("verify", StringComparison.OrdinalIgnoreCase))
                {
                    <div style="margin-top: 0.5rem;">
                        <a href="verify-account?EmailParam=@email&AutoResend=true" style="color: #ef4444; font-weight: 700; text-decoration: underline;">Verify Now</a>
                    </div>
                }
            </div>
        }

        <button class="btn btn-primary" @onclick="HandleLogin" disabled="@isLoading" style="width: 100%; padding: 1rem; font-size: 1rem; letter-spacing: 0.5px;">
            @(isLoading ? "Authenticating..." : "Sign In")
        </button>

        <div style="text-align: center; margin-top: 1.5rem; font-size: 0.95rem;">
            <span style="color: var(--text-muted);">New to the platform? </span>
            <a href="register" style="color: var(--primary-color); text-decoration: none; font-weight: 700; border-bottom: 1px solid transparent; transition: border-color 0.2s;">Create Account</a>
        </div>
    </div>
</div>

@using System.Text.RegularExpressions
@code {
    private string email = "";
    private string password = "";
    private Dictionary<string, string> Errors = new Dictionary<string, string>();
    private string GlobalError = "";
    private bool isLoading = false;
    private bool showPassword = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        GlobalError = "";
        Errors.Clear();
        
        bool isValid = true;
        if (string.IsNullOrWhiteSpace(email)) { Errors["Email"] = "Email is required"; isValid = false; }
        // Simple valid email check on login (optional but good for UX)
        else if (!Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$")) { Errors["Email"] = "Invalid email format"; isValid = false; }

        if (string.IsNullOrWhiteSpace(password)) { Errors["Password"] = "Password is required"; isValid = false; }

        if (!isValid) { isLoading = false; return; }

        var result = await Api.Login(email, password);
        if (result.Success)
        {
            Nav.NavigateTo("/dashboard");
        }
        else
        {
            GlobalError = result.Message;
        }
        
        isLoading = false;
    }
}
